<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.VirtualLab" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/vl_primary</item>
        <item name="colorSecondary">@color/vl_secondary</item>
        <item name="colorTertiary">@color/vl_accent</item>
        <item name="android:windowBackground">@drawable/bg_gradient_soft</item>
        <item name="shapeAppearanceSmallComponent">@style/Shape.VirtualLab.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.VirtualLab.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.VirtualLab.Large</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
    </style>

    <style name="Shape.VirtualLab.Small" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="Shape.VirtualLab.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Shape.VirtualLab.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="TextAppearance.VirtualLab.BottomNav.Active" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.VirtualLab.BottomNav.Inactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>

