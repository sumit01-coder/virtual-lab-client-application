<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card_white"
    android:elevation="4dp"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/imgOfflineThumb"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:background="@drawable/bg_lab_hero_rounded"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_lab_hero" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtOfflineTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textColor="#0F172A"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtOfflineVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtOfflineSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtOfflineDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#94A3B8"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_badge_soft_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:text="Available Offline"
            android:textColor="#0F172A"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnDeleteOfflineNow"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_button_outline_soft"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="Remove"
                android:textColor="#DC2626"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/btnOpenOfflineNow"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="Open"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnOfflineMenu"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_menu_soft"
            android:padding="7dp"
            android:src="@android:drawable/ic_menu_more"
            android:tint="#64748B" />
    </LinearLayout>
</LinearLayout>
