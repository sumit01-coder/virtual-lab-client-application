<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/labsHero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_progress_header_gradient"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Labs"
            android:textColor="#E8EEFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/txtLabsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:maxWidth="270dp"
            android:text="All Labs"
            android:textColor="@android:color/white"
            android:textSize="33sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtLabsSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:maxWidth="272dp"
            android:text="Browse practicals by department with richer previews."
            android:textColor="#E8EEFF"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtLabsHeroPrimary"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_streak_chip"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Visible labs: 0"
                android:textColor="#F8FAFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLabsHeroSecondary"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_streak_chip"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="All departments"
                android:textColor="#F8FAFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:paddingStart="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/chipDeptFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLabs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="128dp" />
</LinearLayout>
