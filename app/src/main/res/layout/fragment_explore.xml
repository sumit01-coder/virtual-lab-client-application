<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/exploreHero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_progress_header_gradient"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explore"
                    android:textColor="#D9E4FF"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:maxWidth="270dp"
                    android:text="Explore Labs"
                    android:textColor="@android:color/white"
                    android:textSize="33sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:maxWidth="272dp"
                    android:text="Discover and start practicals with real simulation previews."
                    android:textColor="#E8EEFF"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_glass_card"
                android:padding="10dp"
                android:src="@drawable/ic_search_20"
                android:tint="@android:color/white" />

            <ImageView
                android:id="@+id/btnFilter"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_glass_card"
                android:padding="10dp"
                android:src="@drawable/ic_filter_20"
                android:tint="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_search_glass"
            android:elevation="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search_20"
                android:tint="#5F6C82" />

            <EditText
                android:id="@+id/edtExploreSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search experiments or topics..."
                android:paddingStart="10dp"
                android:textColor="@color/vl_text"
                android:textColorHint="@color/vl_text_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtExploreHeroPrimary"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_streak_chip"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Visible labs: 0"
                android:textColor="#F8FAFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtExploreHeroSecondary"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_streak_chip"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Difficulty: All"
                android:textColor="#F8FAFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:paddingStart="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/chipDifficultyContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_selected"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="All"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipBeginner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_soft"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Beginner"
                android:textColor="@color/vl_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipIntermediate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_soft"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Intermediate"
                android:textColor="@color/vl_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipAdvanced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_soft"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Advanced"
                android:textColor="@color/vl_text"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Popular Labs"
            android:textColor="@color/vl_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtViewAllExplore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View all"
            android:textColor="@color/vl_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExplore"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="128dp" />

</LinearLayout>
